{
  "name": "taro-template",
  "version": "1.0.0",
  "private": true,
  "description": "Taro 4 + React 18 + TypeScript 跨端（weapp + H5）前端骨架模板",
  "scripts": {
    "build:weapp": "taro build --type weapp && node scripts/patch-weapp-config.js",
    "build:h5": "taro build --type h5",
    "dev:weapp": "taro build --type weapp --watch",
    "dev:h5": "taro build --type h5 --watch",
    "build:weapp:prod": "taro build --type weapp --mode production && node scripts/patch-weapp-config.js",
    "build:h5:prod": "taro build --type h5 --mode production",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss,json}\""
  },
  "dependencies": {
    "@babel/runtime": "^7.24.0",
    "@nutui/nutui-react-taro": "^3.0.20",
    "@tarojs/components": "4.1.9",
    "@tarojs/helper": "4.1.9",
    "@tarojs/plugin-framework-react": "4.1.9",
    "@tarojs/plugin-platform-h5": "4.1.9",
    "@tarojs/plugin-platform-weapp": "4.1.9",
    "@tarojs/react": "4.1.9",
    "@tarojs/runtime": "4.1.9",
    "@tarojs/shared": "4.1.9",
    "@tarojs/taro": "4.1.9",
    "lucide-react": "^1.21.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@tarojs/cli": "4.1.9",
    "@tarojs/webpack5-runner": "4.1.9",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.2.0",
    "@types/webpack-env": "^1.18.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-preset-taro": "4.1.9",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest": "^29.7.0",
    "prettier": "^3.9.0",
    "react-refresh": "^0.18.0",
    "sass": "^1.71.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.4.0",
    "webpack": "^5.90.0"
  }
}
